# Railway injects DATABASE_URL automatically when Postgres is linked. For local
# development, point this at your own Postgres instance.
DATABASE_URL=

# Collector only — never expose these to the web service.
CONED_EMAIL=
CONED_PASSWORD=
CONED_TOTP_SECRET=
# Only needed when the account contains more than one active electric service.
CONED_ACCOUNT_URN=

# Protects the manual MFA completion endpoint with a long random bearer token.
INGEST_TOKEN=

# Fernet key used to encrypt persisted Con Edison cookies. Generate with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
SESSION_ENCRYPTION_KEY=

# Web only. Use city-level coordinates if you do not want to disclose a precise location.
# When omitted, demo mode uses central New York City.
WEATHER_LATITUDE=
WEATHER_LONGITUDE=

# Web-only cost model. Replace these illustrative defaults with your current bill/rate.
ENERGY_RATE_PER_KWH=0.338
MONTHLY_FIXED_CHARGE=17.80

POLL_SECONDS=300
METER_KEY=home
